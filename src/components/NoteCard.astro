---
const { note } = Astro.props;
const { title, lecture, semester, subject, date, order, description } =
  note.data;
---

<a href={`/semesters/${note.id}`} class="note-card">
  <div class="top-bar"></div>
  <div class="card-content">
    <div class="card-top">
      <span class="lecture-label">{lecture}</span>
      <span class="note-date"
        >{
          date
            ? date.toLocaleDateString("en-GB", {
                day: "numeric",
                month: "long",
                year: "numeric",
              })
            : "No date provided"
        }</span
      >
    </div>
    <h3 class="note-title">{title}</h3>
    <p class="note-desc">
      {description}
    </p>
  </div>
</a>

<style>
  .note-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    text-decoration: none !important;
    transition: all 0.25s ease;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .note-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow:
      0 3px 12px rgba(0, 0, 0, 0.07),
      0 1px 4px rgba(0, 0, 0, 0.07);
  }
  .card-content {
    padding: 20px;
  }
  .top-bar {
    height: 3px;
    width: 100%;
    background: var(--accent);
    opacity: 0.7;
  }
  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }
  .lecture-label {
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 2px 8px;
    border-radius: 4px;
  }
  .note-date {
    font-size: 11px;
    color: var(--text-secondary);
    font-weight: 500;
  }
  .note-title {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.4;
  }
  .note-desc {
    font-size: 13px;
    color: var(--text-gray);
    margin-top: 10px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
